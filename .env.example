# Supabase – öffentliche Client-Konfiguration
# Werte findest du im Supabase-Dashboard unter: Project Settings → API
# Kopiere diese Datei zu .env.local und trage echte Werte ein (NICHT committen).

NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key

# Luminalis KI-Dialog & Frequenzintelligenz (serverseitig)
# Diese Werte werden NUR serverseitig genutzt. Kein NEXT_PUBLIC_ Prefix.
# Solange AI_ENABLED nicht "true" ist oder ein Schlüssel fehlt, bleibt der
# KI-Dialog ruhig deaktiviert – die App läuft trotzdem ohne Fehler weiter.
AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=
